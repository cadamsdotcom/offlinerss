# Tailscale auth key (get from https://login.tailscale.com/admin/settings/keys)
TS_AUTHKEY=tskey-auth-xxx

# API secret (required for all requests: ?secret=xxx)
API_SECRET=your-secret-here

# Optional tunables (defaults shown)
# ENTRY_TTL_MS=86400000     # how long a rendered discussion page stays cached (24h)
# ENTRY_MAX=500             # max cached discussion pages before LRU eviction
# FEED_TTL_MS=1800000       # how long an assembled feed is reused (30m)
# FETCH_CONCURRENCY=3       # parallel page fetches when building a feed

# Optional persistent cache (Upstash Redis / Vercel KV). Only needed on
# serverless hosts, where the in-memory cache is wiped between cold starts;
# the long-running Docker deploy doesn't need these. On Vercel, connecting an
# Upstash/KV store injects these automatically — no manual setup required.
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxxxx
