# API secret (required for all requests: ?secret=xxx)
# On Vercel, set this as a project environment variable.
API_SECRET=your-secret-here

# Optional tunables (defaults shown)
# ENTRY_TTL_MS=86400000     # default cached lifetime; fallback for ARTICLE_TTL_MS (24h)
# ARTICLE_TTL_MS=86400000   # how long a rendered article stays cached — immutable, so long (defaults to ENTRY_TTL_MS)
# COMMENTS_TTL_MS=1800000   # how long a discussion stays cached before re-rendering for new comments (30m)
# FAIL_TTL_MS=600000        # how long a failed render is skipped before being retried (10m)
# STALE_TTL_MS=86400000     # how long the last good render is kept to serve on a failed re-render (24h)
# ENTRY_MAX=500             # max cached entries before LRU eviction
# FETCH_CONCURRENCY=3       # parallel page fetches when building a feed
# (The feed itself is reassembled from a fresh source fetch on every request,
#  so the story list is always current; only per-story content is cached.)

# Bot-wall fallback (feeds /hn.xml, /lobsters.xml).
# When an article is behind a bot wall / captcha (Anubis, Cloudflare), the
# feeds fall back to Jina Reader (https://r.jina.ai), which fetches the
# page from its own infrastructure. On by default. This sends the article URL
# to Jina's servers; set JINA_READER=0 to opt out (also accepts false/off/no).
# JINA_API_KEY is optional (raises the rate limit; works without one).
# JINA_READER=0
# JINA_API_KEY=jina_xxxxx

# Persistent cache (Upstash Redis / Vercel KV). Recommended on serverless
# hosts, where the in-memory cache is wiped between cold starts and every build
# would otherwise re-fetch all discussion pages. On Vercel, connecting an
# Upstash/KV store injects these automatically — no manual setup required.
# Omit them locally to just use the in-memory cache.
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxxxx
